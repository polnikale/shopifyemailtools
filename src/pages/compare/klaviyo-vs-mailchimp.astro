            <tr><td>Shopify events</td><td>Browse, cart, orders, catalog</td><td>Orders, products, basic cart</td></tr>
            <tr><td>Billing</td><td>Active profiles + SMS</td><td>Contacts</td></tr>
            <tr><td>SMS</td><td>Native, coordinated</td><td>Available, peripheral</td></tr>
