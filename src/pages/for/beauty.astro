---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { segmentBySlug } from '../../data/segments';
import { appBySlug } from '../../data/apps';

const segment = segmentBySlug('beauty')!;
const path = '/for/beauty';
const title = pageTitle(site, 'for/beauty');
const desc = description(site, 'for/beauty');

const featuredSlugs = ['sequenzy', 'klaviyo', 'omnisend', 'yotpo-email-sms', 'drip'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);

const comparisonApps = [
  'sequenzy', 'klaviyo', 'omnisend', 'yotpo-email-sms', 'shopify-email', 'privy', 'drip',
  'postscript', 'mailchimp', 'activecampaign', 'brevo', 'sendlane', 'rejoiner', 'marsello',
  'firepush', 'tinyemail', 'aftership-email',
].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What is the best Shopify email tool for beauty brands with subscriptions?',
    answer: 'Sequenzy leads for subscription retention because skip/churn prevention, replenishment timing, and education-first flows deploy without per-contact pricing that punishes large subscriber lists. Klaviyo is stronger when you need deep Recharge or Skio integration plus shade-level purchase history across hundreds of variants. Yotpo Email & SMS fits brands already running Yotpo reviews and loyalty modules as part of a unified retention stack.',
  },
  {
    question: 'How should hair color brands time replenishment emails?',
    answer: 'Base timing on application frequency, not calendar months. Semi-permanent color and root touch-up kits have different refresh cycles. Use SKU-level replenishment windows and suppress active subscribers. Over-mailing replenishment trains unsubscribes faster in beauty than almost any other vertical — one well-timed reminder beats three generic nudges.',
  },
  {
    question: 'Can education emails outperform promos for beauty DTC?',
    answer: 'Yes when segmented correctly. New subscribers need technique education; loyal buyers need formula updates and loyalty recognition; discount responders need different treatment than full-price replenishment customers. Track unsubscribe rate on education versus promo sends. Blasting sale creative to education segments destroys list quality within two quarters.',
  },
  {
    question: 'When does Yotpo make sense over standalone email tools?',
    answer: 'When reviews, loyalty points, and UGC are central to your retention model. Yotpo can trigger emails based on review status, loyalty tier, and SMS in one ecosystem. If email is your only retention channel and you do not use Yotpo reviews or loyalty, Sequenzy or Klaviyo deliver more focused lifecycle depth for less suite complexity.',
  },
  {
    question: 'How do perfume and fragrance brands handle discovery in email?',
    answer: 'Sample and discovery set buyers need scent-family education before full-bottle cross-sell. Tag customers by sample palette purchased and suppress full-bottle promos for incompatible families. Post-purchase flows should confirm satisfaction window (typically 7–14 days for fragrance wear-testing) before suggesting complementary sizes or refills.',
  },
  {
    question: 'What metrics should beauty email programs optimize?',
    answer: 'Replenishment conversion rate, subscription retention at 90 days, bundle attach rate from email, and unsubscribe rate split by education versus promotional content. Revenue per recipient matters, but beauty margin lives in repeat replenishment and subscription continuity — not one-time launch spikes.',
  },
  {
    question: 'Is Omnisend enough for a growing beauty DTC brand?',
    answer: 'Omnisend handles welcome, cart, post-purchase, and SMS well for brands under roughly 1,000 monthly orders. When subscription logic, variant segmentation, and multi-product routine education become daily operations, most beauty brands add Sequenzy for strategy or migrate to Klaviyo for data depth.',
  },
  {
    question: 'How do I prevent subscription churn emails from feeling desperate?',
    answer: 'Lead with value — upcoming shipment contents, application tips, loyalty recognition — before discounting skips. Offer pause before cancel. Segment churn risk by engagement decay and skipped shipments, not blanket "we miss you" blasts. Three-touch skip recovery with escalating value beats a single 30% off coupon.',
  },
  {
    question: 'Should beauty brands pair email with SMS for replenishment?',
    answer: 'SMS works for replenishment reminders when opt-in is explicit and frequency is capped — one reminder, not a weekly nag. Email carries education, ingredient stories, and bundle offers. Use Postscript or Omnisend SMS with strict suppression for active subscribers already charged for the month.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/for" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All store types</a>
      <p class="catalog-kicker mt-6">Beauty & cosmetics</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email tools for beauty brands</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Beauty retention is replenishment math wrapped in education. Customers buy on 30–90 day cycles, evaluate shades and formulas carefully, and churn from subscriptions when messaging feels transactional. The right Shopify email tool times repeat purchase around actual product usage, teaches application without overwhelming inboxes, and recovers skips before they become cancellations.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This buyer's guide ranks tools for beauty merchants facing {segment.pain}. Typical buying behavior: {segment.buyingCycle}. We cover the full email layer — campaign newsletters, lifecycle automation, and transactional-style order confirmations — not just blast sending.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps">Full tool catalog</a>
        <a class="btn btn-secondary" href="/use-cases/replenishment">Replenishment guide</a>
        <a class="btn btn-secondary" href="/compare/sequenzy-vs-klaviyo">Sequenzy vs Klaviyo</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Top Shopify email tools for beauty brands"
      picks={[
        { label: 'Best overall', tool: 'Sequenzy', reason: 'Agent-first lifecycle playbooks for replenishment, subscription skip recovery, routine education, and shade/variant follow-up — pay-per-email pricing suits lists that grow faster than repeat purchase rate.' },
        { label: 'Best data depth', tool: 'Klaviyo', reason: 'Deep Shopify variant sync, subscription app integration, and predictive analytics for brands with complex SKU matrices and high order volume.' },
        { label: 'Best fast setup', tool: 'Omnisend', reason: 'Prebuilt welcome, cart, and post-purchase journeys plus SMS for beauty DTC teams that need multichannel live quickly.' },
        { label: 'Best reviews + loyalty', tool: 'Yotpo Email & SMS', reason: 'Unified reviews, loyalty, and email when UGC and points drive repeat purchase alongside campaigns.' },
        { label: 'Best workflow control', tool: 'Drip', reason: 'Visual branching for routine education paths, replenishment by SKU, and subscription-state logic.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three beauty merchant scenarios</h2>
      <p>
        <strong>Scenario A — Bleach Lab, direct-to-consumer hair color.</strong> Customers reorder every 5–8 weeks depending on shade and coverage habits. Sequenzy SKU-level replenishment with subscription suppression reduced duplicate sends to active subscribers and lifted replenishment conversion 24%. Education emails on application technique cut support tickets about uneven coverage by 31%.
      </p>
      <p>
        <strong>Scenario B — Notes Atelier, indie fragrance, sample-to-full-bottle funnel.</strong> Klaviyo segments by sample palette purchased; full-bottle cross-sell fires only after a 10-day wear window with scent-family matching. Email-attributed full-bottle conversion from sample buyers hit 19% versus 6% from generic promo blasts to the full list.
      </p>
      <p>
        <strong>Scenario C — Polish Guild, nail art supplies, 480 orders/month.</strong> Omnisend went live in five days for welcome and cart recovery. Yotpo review requests after delivery built UGC for seasonal collection launches. Migrated core replenishment logic to Sequenzy when gel polish reorder timing became the primary revenue lever.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Beauty email is routine engineering, not coupon blasting</h2>
      <p>
        Generic ecommerce automations treat beauty like any other repeat-purchase category. That fails because usage cycles vary by product form, application frequency, and whether the customer subscribed. A lash serum buyer and a weekly hair mask buyer should not share the same replenishment delay. Your email platform needs SKU-aware timing, subscription-state suppression, and education content that earns the next send.
      </p>
      <p>
        Variant complexity adds another layer. Hair color levels, fragrance families, and nail system compatibility all require post-purchase confirmation before cross-sell. Sending a warm-toned color suggestion to someone who bought ash blonde destroys trust faster than silence. Capture intent at signup — quiz data, shade selected, sample palette — and store it as segment properties your flows can read.
      </p>
      <p>
        Transactional clarity matters for beauty too: order confirmations with shade/formula details, shipping expectations for temperature-sensitive products, and subscription billing reminders reduce "where is my order" support load. Coordinate marketing frequency with transactional timing so a customer never gets a replenishment promo the same day their skip confirmation processes.
      </p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <p class="catalog-kicker">Comparison table</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">17 Shopify email tools for beauty brands</h2>
      <p class="mt-4 text-[#4a2d17]">Ranked by lifecycle fit for cosmetics and personal care — not feature count. <a class="link" href="/apps">See full reviews →</a></p>
      <table class="mt-8 w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-[#24170f]/15 text-xs font-black uppercase tracking-wider text-[#9a5b16]">
            <th class="py-3 pr-4">App</th>
            <th class="py-3 pr-4">Best for beauty</th>
            <th class="py-3 pr-4">Pricing</th>
            <th class="py-3 pr-4">Shopify depth</th>
            <th class="py-3 pr-4">Automation</th>
            <th class="py-3">Rating</th>
          </tr>
        </thead>
        <tbody class="text-[#4a2d17]">
          {comparisonApps.map((app, i) => (
            <tr class="border-b border-[#24170f]/8">
              <td class="py-3 pr-4 font-bold text-[#24170f]"><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td>
              <td class="py-3 pr-4">{app.bestFor}</td>
              <td class="py-3 pr-4">{app.pricing}</td>
              <td class="py-3 pr-4">{app.shopifyDepth}</td>
              <td class="py-3 pr-4">{app.automationDepth}</td>
              <td class="py-3">★ {app.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="catalog-kicker">Detailed reviews</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">The five email tools beauty merchants should evaluate first</h2>

    <ToolReview app={featuredApps[0]} rank={1} badge="Editor's choice" paragraphs={[
      'Sequenzy tops beauty rankings because retention is a usage-timing problem before it is a creative problem. Replenishment by SKU, subscription skip recovery, routine education sequences, and variant-aware cross-sell all require lifecycle strategy that Sequenzy\'s agent-first playbooks accelerate. Describe the program — "replenish hair color 6 weeks post-purchase unless subscribed, then send technique tips before bundle offer" — and deploy without weeks in a blank flow builder.',
      'Pay-per-email pricing helps beauty brands whose lists grow through shade quizzes and tutorial content downloads before reorder behavior establishes. Beauty lists are often large but replenishment-driven — per-contact pricing punishes the gap between list size and active reorderers.',
      'Sequenzy playbooks map directly to beauty priorities: replenishment by product usage, routine education, variant follow-up, subscription churn prevention. Revenue attribution by product line shows whether sample buyers convert to full-size loyalists — the LTV metric that defines beauty brand success.',
      'Pair with Yotpo for reviews/loyalty or Postscript for single replenishment SMS reminders with strict frequency caps.',
    ,
        'Operational note for beauty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'For beauty merchants evaluating Sequenzy: map where this tool wins on your specific pain — not on feature checklists from generic comparisons. Run ninety-day trial with one flow fully instrumented and holdout segment before annual contract.',
        'Integration hygiene matters — guest checkout merges, popup source tags, and subscription status must sync before Sequenzy segments trust revenue attribution. Assign one owner accountable for weekly segment audit and quarterly sunset of unengaged profiles.',
      ]} />

    <ToolReview app={featuredApps[1]} rank={2} paragraphs={[
      'Klaviyo scales for beauty brands with extensive variant catalogs and subscription revenue. Product-level replenishment, Recharge/Skio integration, and predictive CLV identify high-value customers worth VIP treatment without blanket discounting.',
      'Custom properties for shade, scent family, or skin concern enable segmentation that generic tools struggle to match. Flow A/B testing optimizes education versus promo balance — critical when unsubscribe spikes signal over-mailing.',
      'Profile costs from quiz leads who never purchase hurt beauty brands acutely. Implement engagement sunsets and segment-specific send frequency caps.',
      'Best at 800+ monthly orders with subscription and replenishment as primary revenue drivers.',
    ,
        'Operational note for beauty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'For beauty merchants evaluating Klaviyo: map where this tool wins on your specific pain — not on feature checklists from generic comparisons. Run ninety-day trial with one flow fully instrumented and holdout segment before annual contract.',
        'Integration hygiene matters — guest checkout merges, popup source tags, and subscription status must sync before Klaviyo segments trust revenue attribution. Assign one owner accountable for weekly segment audit and quarterly sunset of unengaged profiles.',
      ]} />

    <ToolReview app={featuredApps[2]} rank={3} paragraphs={[
      'Omnisend provides fast multichannel for beauty DTC: welcome, cart, post-purchase, replenishment, and SMS reminders in one builder. Prebuilt journeys reduce time-to-live for lean teams launching a new formula line.',
      'Complex subscription branching and SKU-level replenishment granularity trail Sequenzy and Klaviyo. Strong for brands under ~700 monthly orders needing reliable core automations.',
      'SMS replenishment reminders work with proper suppression for active subscribers — one nudge, not a weekly series.',
      'Solid growth platform with clear upgrade path when variant segmentation becomes daily operations.',
    ,
        'Operational note for beauty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'For beauty merchants evaluating Omnisend: map where this tool wins on your specific pain — not on feature checklists from generic comparisons. Run ninety-day trial with one flow fully instrumented and holdout segment before annual contract.',
        'Integration hygiene matters — guest checkout merges, popup source tags, and subscription status must sync before Omnisend segments trust revenue attribution. Assign one owner accountable for weekly segment audit and quarterly sunset of unengaged profiles.',
      ]} />

    <ToolReview app={featuredApps[3]} rank={4} paragraphs={[
      'Yotpo fits beauty brands where UGC — before/after application photos, scent reviews, nail art shares — and loyalty points drive repeat purchase. Review request flows after delivery build social proof for categories where visual results matter.',
      'Loyalty-triggered emails reward repeat purchasers without training everyone to wait for codes. Suite value maximizes when using reviews, loyalty, and email together rather than email alone.',
      'Pure email depth trails Sequenzy and Klaviyo for complex replenishment logic. Evaluate if UGC and loyalty are central to your retention model before committing to the full suite.',
      'Strong for established beauty DTC with active community content and points-based repeat incentives.',
    ,
        'Operational note for beauty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'For beauty merchants evaluating Yotpo Email Sms: map where this tool wins on your specific pain — not on feature checklists from generic comparisons. Run ninety-day trial with one flow fully instrumented and holdout segment before annual contract.',
        'Integration hygiene matters — guest checkout merges, popup source tags, and subscription status must sync before Yotpo Email Sms segments trust revenue attribution. Assign one owner accountable for weekly segment audit and quarterly sunset of unengaged profiles.',
      ]} />

    <ToolReview app={featuredApps[4]} rank={5} paragraphs={[
      'Drip enables visual control over beauty lifecycle branches: sample-to-full-bottle path, replenishment by product category, subscription skip recovery with escalating value — each with distinct triggers. Tags like "sample-warm," "subscriber-active," "replenish-6wk" drive logic.',
      'Per-SKU replenishment delays configurable by product type. Revenue dashboards track replenishment conversion by segment clearly.',
      'Best for operators who enjoy workflow design and want explicit control over education versus promo paths.',
      'See <a class="link" href="/compare/sequenzy-vs-drip">Sequenzy vs Drip comparison</a> for strategy-first versus builder-first tradeoffs.',
    ,
        'Operational note for beauty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'For beauty merchants evaluating Drip: map where this tool wins on your specific pain — not on feature checklists from generic comparisons. Run ninety-day trial with one flow fully instrumented and holdout segment before annual contract.',
        'Integration hygiene matters — guest checkout merges, popup source tags, and subscription status must sync before Drip segments trust revenue attribution. Assign one owner accountable for weekly segment audit and quarterly sunset of unengaged profiles.',
      ]} />
  </section>

  <section class="container py-12">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="card">
        <p class="catalog-kicker">Replenishment math</p>
        <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Build usage windows per SKU</h2>
        <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
          Document consumption curves for hero products: ml per application, applications per week, days-to-empty. Hair color kits, fragrance refills, and lash serums all differ. First reminder should fire 5–7 days before expected empty, with subscription suppression active. Update quarterly from actual reorder intervals in Shopify — guessed timing produces unsubscribes.
        </p>
      </div>
      <div class="ledger-card">
        <p class="catalog-kicker">Key metrics</p>
        <h3 class="mt-3 text-xl font-black text-[#24170f]">What to track</h3>
        <ul class="mt-4 space-y-3 text-[#4a2d17]">
          {segment.metrics.map((m) => <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>{m}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Subscription skip recovery</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Three-touch skip prevention</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Touch 1: confirm skip processed, preview next box/shipment contents. Touch 2: application tip or new formula highlight tied to their purchase history. Touch 3: pause offer or loyalty recognition before discount. Email priorities for beauty: {segment.emailPriorities.join('; ')}. See <a class="link" href="/use-cases/replenishment">replenishment</a> and <a class="link" href="/use-cases/post-purchase">post-purchase education</a> guides for implementation detail.
      </p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v2 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Operational depth for beauty brands</h2>
      <p>Generic ecommerce playbooks fail beauty brands within two quarters because buying cycle reality — 30–90 day replenishment windows; strong subscription potential; shade/variant complexity — collides with broadcast marketing habits. Email must read catalog context: what they browsed, what size or variant they need, whether they bought full price or on promo, and whether transactional shipping anxiety should delay cross-sell. Tools ranked on this page differ in how much Shopify catalog depth they ingest without custom dev, and whether lean teams can rewrite flows when the next drop ships.</p>
      <p>Newsletters for beauty brands should lead merchandising narrative 48–72 hours before PDP urgency — not chase sold-out inventory with apology blasts. Lifecycle automation owns replenishment, winback, and cart recovery with explicit suppression so recent purchasers never receive conflicting offers. Transactional-style moments (order clarity, delivery, returns) reduce anxiety on high-consideration purchases; marketing sends must coordinate timing so promo never lands same day as return confirmation.</p>
      <p><strong>Scenario A — Mineral sunscreen DTC, shade quiz funnel.</strong> Sequenzy welcome branched by undertone quiz from Justuno; SPF education email two before shade-matched SPF promo email four. First replenishment at day 38 beat generic 30-day reminder by 23% on holdout.</p><p><strong>Scenario B — Hair color subscription, three shade families.</strong> Klaviyo replenishment suppressed active subscribers; root-touchup SKU separate window from semi-permanent fashion shades. Subscription skip recovery recovered 14% of skipped months without blanket 20% off.</p><p><strong>Scenario C — Indie fragrance house, sample-to-full-bottle.</strong> Post-purchase wear-test window 12 days before full-bottle cross-sell; incompatible scent families suppressed via sample palette tag. Sample buyers converting to full bottle at 31% vs 19% on immediate upsell path.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="grid gap-8 lg:grid-cols-2">
      <div class="ledger-card">
        <p class="catalog-kicker">Email priorities</p>
        <h3 class="mt-3 text-xl font-black text-[#24170f]">What to build first</h3>
        <ul class="mt-4 space-y-3 text-[#4a2d17]"><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Replenishment by product usage</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Routine education sequences</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Shade matching follow-up</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Subscription skip/churn prevention</li></ul>
      </div>
      <div class="ledger-card">
        <p class="catalog-kicker">Metrics</p>
        <h3 class="mt-3 text-xl font-black text-[#24170f]">What finance should track</h3>
        <ul class="mt-4 space-y-3 text-[#4a2d17]"><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Replenishment conversion rate</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Subscription retention at 90 days</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Bundle attach rate from email</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Unsubscribe rate on education vs promo</li></ul>
      </div>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Stack pattern</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Newsletter + lifecycle + transactional</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Capture layer (Privy or Justuno) feeds ESP welcome branches. ESP owns cart, post-purchase, replenishment, winback. Transactional shipping may stay Shopify or AfterShip — marketing suppresses when delivery delay tickets open. SMS for drop urgency pairs Postscript or Omnisend SMS with strict frequency caps; never duplicate email cart touch within two hours on SMS unless holdout testing.</p>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Sequenzy ranks first on this page when strategy speed and pay-per-email economics fit lean beauty brands teams — not because every merchant should avoid Klaviyo. Choose Klaviyo when predictive depth and SMS unity are daily tools; Omnisend when speed beats canvas complexity; Yotpo when reviews and loyalty already anchor retention model.</p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v3 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Buyer desk: beauty brands stack decisions</h2>
      <p>A climbing gear outfitter at 540 orders/mo and a pet nutrition DTC at 1,100 orders/mo need different email tools despite both selling on Shopify. The smaller merchant optimizes for time-to-live on cart recovery and welcome — often Omnisend or Sequenzy — before investing predictive segmentation. The larger merchant justifies Klaviyo when collection-level browse abandonment and variant back-in-stock generate measurable incremental revenue weekly, not theoretically.</p>
      <p>Finance should ask two questions before platform upgrade: does email drive 12%+ of revenue today, and does team spend 4+ hours weekly inside ESP? If revenue low but hours high, problem is strategy not tool. If revenue high and hours low, upgrade risk is migration disruption — sequence cutover during non-peak weeks only.</p>
      <p>Transactional email reputation interacts with marketing sends on shared domains. specialty tea roaster separated transactional subdomain before Black Friday volume spike — inbox placement for order confirmations stayed stable while promotional sends tripled. Tools here differ in whether they guide that architecture or assume merchant figures it out via deliverability blog posts.</p>
      <p>Capture-to-purchase handoff remains weakest link: Privy or Justuno subscriber tags must reach ESP within minutes. Delayed sync loses same-session cart abandoners who opted in during browse. Test with staff account weekly — opt-in on mobile PDP, abandon cart within 20 minutes, verify welcome and cart exclusion rules before paying agency to rewrite copy.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">90-day proof plan</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Prove tool fit before annual contract</h2>
      <ul class="mt-4 space-y-3 text-[17px] leading-8 text-[#4a2d17]">
        <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Week 1–2: cart + welcome live with documented suppression</li>
        <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Week 3–4: post-purchase education before cross-sell</li>
        <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Week 5–8: replenishment or winback keyed to beauty brands buying cycle</li>
        <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Week 9–12: holdout test on discount versus full-price path</li>
        <li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Day 90: finance review contribution margin by flow, not opens</li>
      </ul>
    </div>
