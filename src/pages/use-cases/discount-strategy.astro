---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const uc = useCaseBySlug('discount-strategy')!;
const path = '/use-cases/discount-strategy';
const title = pageTitle(site, 'use-cases/discount-strategy');
const desc = description(site, 'use-cases/discount-strategy');

const featuredSlugs = ['sequenzy', 'klaviyo', 'drip', 'omnisend', 'privy'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);

const comparisonApps = [
  'sequenzy', 'klaviyo', 'drip', 'omnisend', 'privy', 'shopify-email',
  'mailchimp', 'brevo', 'yotpo-email-sms', 'rejoiner',
].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What Shopify email tool supports disciplined discount strategy best?',
    answer: 'Sequenzy ranks first for discount governance playbooks — segment-by-sensitivity logic, collision suppression across flows, and full-price paths for loyalists. Klaviyo wins at scale with predictive discount affinity and holdout testing. Drip suits operators who want explicit discount branches visible on canvas.',
  },
  {
    question: 'Should every automation include a discount code?',
    answer: 'No. Default 10% in welcome, cart, browse, and winback trains waiting. Full-price segments — vinyl collectors, outdoor gear repeat buyers — should see proof and urgency before codes. Document which flows allow discounts in email one versus email three only.',
  },
  {
    question: 'How do I prevent discount stacking across email flows?',
    answer: 'Global rule: one active offer per customer. Cart suppresses welcome; winback suppresses cart; launch suppresses winback. Tag recent_redemption for 14 days and exclude from new offer flows. Privy popup plus cart plus winback stacking destroys margin silently.',
  },
  {
    question: 'How should discount depth vary by cart value?',
    answer: 'Cap incentive by margin floor — $400 keyboard build gets free shipping before 15% off; $28 tea tin gets nothing until touch three. Finance-approved ladder documented in platform logic, not marketer intuition per send.',
  },
  {
    question: 'What is discount sensitivity segmentation?',
    answer: 'Customers who redeem frequently versus never. Predicted or historical: prior redemption in last 90 days, welcome source was coupon popup, winback needed code to return. Sensitive segments get graduated discounts; loyalists get full-price paths with social proof.',
  },
  {
    question: 'How do newsletters interact with discount strategy?',
    answer: 'Editorial newsletters from artisan coffee and specialty tea brands should not always carry codes — alternate proof-only and soft-offer issues. VIP and full-price loyalists receive newsletter without footer coupon via dynamic content blocks.',
  },
  {
    question: 'What metrics track discount dependency?',
    answer: 'Full-price order percentage, discount redemption rate, margin after all incentives, repeat purchase without discount within 60 days. Rising redemption with flat revenue signals trained waiting.',
  },
  {
    question: 'Can Privy and lifecycle platforms share discount rules?',
    answer: 'Privy passes popup offer into Shopify; lifecycle platform must honor same code limits and suppress duplicate offers in welcome email one. Mismatch between popup promise and welcome email causes immediate unsubscribes on board game and vinyl launches.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All use cases</a>
      <p class="catalog-kicker mt-6">Discount strategy</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email tools for discount strategy</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Discount strategy in email is governance across newsletters, lifecycle flows, and transactional touchpoints — not a race to the deepest coupon. A vinyl shop training collectors to wait for 20% off sitewide destroys limited-pressing margin; a board game publisher stacking launch, cart, and winback codes bleeds Kickstarter-thin profits. The right Shopify email tool segments by discount sensitivity, suppresses stacking, and protects full-price loyalists in every automation.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This playbook ranks email tools for {uc.job}. We evaluated cross-flow collision rules, margin-aware caps, and full-price path coverage — not which platform generates random coupon codes fastest. Discount strategy is the connective tissue between Privy capture, lifecycle automations, and newsletter — when it is undocumented, every flow owner invents their own code depth and finance loses visibility.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps">Full tool catalog</a>
        <a class="btn btn-secondary" href="/use-cases/abandoned-cart">Abandoned cart</a>
        <a class="btn btn-secondary" href="/use-cases/vip-segments">VIP segments</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Top Shopify email tools for discount strategy"
      picks={[
        { label: 'Best overall', tool: 'Sequenzy', reason: 'Discount governance playbooks with sensitivity segmentation, stacking suppression, and full-price paths across lifecycle flows.' },
        { label: 'Best data depth', tool: 'Klaviyo', reason: 'Predictive discount affinity, holdout testing, and margin reporting by segment and flow.' },
        { label: 'Best workflow control', tool: 'Drip', reason: 'Visual discount branches and redemption tags explicit on canvas for auditability.' },
        { label: 'Best fast setup', tool: 'Omnisend', reason: 'Prebuilt flows with basic discount splits live quickly for SMB catalogs.' },
        { label: 'Best capture alignment', tool: 'Privy', reason: 'Popup offer sync with downstream welcome and cart when discount strategy starts at opt-in.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three discount strategy merchant scenarios</h2>
      <p>
        <strong>Scenario A — Vinyl label, collector full-price segment.</strong> Sequenzy discount governance: customers with 2+ full-price orders in 12 months never saw automation discounts — only early access. Discount-sensitive segment got graduated codes in cart email three only. Full-price order rate rose from 54% to 71% over two quarters; total revenue up 12% with fewer codes issued.
      </p>
      <p>
        <strong>Scenario B — Board game publisher, launch margin protection.</strong> Klaviyo global suppression: active launch pricing blocked cart and winback discounts for 14 days. Recent redemption tag excluded buyers from stacked offers. Margin after all incentives rose 8 points versus prior launch season when popup, cart, and winback codes compounded.
      </p>
      <p>
        <strong>Scenario C — Mechanical keyboard shop, cart value ladder.</strong> Drip branched cart discount by value band — free shipping over $250 before any percentage off; keycap-only carts under $40 reminder-only. SMS cart from Postscript inherited same ladder via shared tags. Recovered cart revenue up 6%; average discount depth down 11%.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="catalog-kicker">Execution playbook</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Discount strategy operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-[#4a2d17]">
        <div>
          <h3 class="font-black text-[#24170f]">Trigger</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.trigger}</p>
        </div>
        <div>
          <h3 class="font-black text-[#24170f]">Timing</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.timing}</p>
        </div>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Exclusions</h3>
        <ul class="mt-3 space-y-2">
          {uc.exclusions.map((e) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{e}</li>)}
        </ul>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Metrics</h3>
        <ul class="mt-3 space-y-2">
          {uc.metrics.map((m) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{m}</li>)}
        </ul>
      </div>
      <p class="mt-8 text-[17px] leading-8 text-[#4a2d17]">
        Common mistakes: {uc.mistakes.join('; ')}.
      </p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <p class="catalog-kicker">Comparison table</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">10 Shopify email tools for discount strategy</h2>
      <table class="mt-8 w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-[#24170f]/15 text-xs font-black uppercase tracking-wider text-[#9a5b16]">
            <th class="py-3 pr-4">App</th>
            <th class="py-3 pr-4">Discount governance fit</th>
            <th class="py-3 pr-4">Pricing</th>
            <th class="py-3 pr-4">Shopify depth</th>
            <th class="py-3 pr-4">Automation</th>
            <th class="py-3">Rating</th>
          </tr>
        </thead>
        <tbody class="text-[#4a2d17]">
          {comparisonApps.map((app, i) => (
            <tr class="border-b border-[#24170f]/8">
              <td class="py-3 pr-4 font-bold text-[#24170f]"><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td>
              <td class="py-3 pr-4">{app.bestFor}</td>
              <td class="py-3 pr-4">{app.pricing}</td>
              <td class="py-3 pr-4">{app.shopifyDepth}</td>
              <td class="py-3 pr-4">{app.automationDepth}</td>
              <td class="py-3">★ {app.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="catalog-kicker">Detailed reviews</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">Five apps for discount strategy</h2>

    <ToolReview
      app={featuredApps[0]}
      rank={1}
      badge="Editor's choice"
      paragraphs={[
        'Sequenzy leads discount strategy because margin erosion is a cross-flow problem. Teams fix cart discounting while welcome still blasts 15% off — trained waiting persists. Sequenzy governance playbooks document sensitivity segments, redemption tags, and full-price paths across welcome, cart, browse, winback, and launch in one coherent model.',
        'Agent-first discount edits: "full-price loyalists skip all codes; sensitive segment max 10% in email three only; suppress if redeemed in 14 days." Finance can audit playbook logic without reading boolean trees.',
        'Pay-per-email pricing reduces pressure to discount for engagement — per-contact platforms incentivize blasting codes to justify list cost. Sequenzy aligns economics with disciplined sends.',
        'Not Klaviyo for enterprise holdout testing at scale — pair when discount incrementality needs statistical rigor. Publish offer calendar PDF to support team so cart recovery codes match onsite banners — mismatch drives tickets faster than missing codes.',
        'Operational note for discount strategy: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
        'Sequenzy implementation for discount strategy should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on discount strategy flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[1]}
      rank={2}
      paragraphs={[
        'Klaviyo predictive discount affinity powers sensitivity segmentation at volume — predicted full-price likely subscribers skip codes in cart email one automatically.',
        'Holdout testing proves whether winback discount drives incremental orders versus natural return. Run quarterly; results often cut unnecessary codes 20–30%.',
        'Flow-level reporting shows discount redemption by automation — identify which flow trains waiting most aggressively.',
        'Complex boolean logic handles exotic rules — recent launch plus VIP plus redemption tag — but requires dedicated operator maintenance.',
        'Operational note for discount strategy: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
        'Klaviyo implementation for discount strategy should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on discount strategy flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[2]}
      rank={3}
      paragraphs={[
        'Drip canvas makes discount branches auditable — finance and marketing review same visual: who gets code, when, max depth.',
        'Tag recent_redemption at checkout webhook; exclude tagged profiles from new offer flows 14 days. Explicit and visible.',
        'Per-contact pricing; strong for focused catalogs with custom discount logic.',
        'Pick Drip when discount governance needs visual audit trail for stakeholders.',
        'Operational note for discount strategy: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
        'Drip implementation for discount strategy should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on discount strategy flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[3]}
      rank={4}
      paragraphs={[
        'Omnisend basic discount splits in prebuilt flows — sufficient for SMB with simple sensitive versus loyalist two-path model.',
        'Struggles with complex cross-flow suppression — manual tags when launch, cart, winback overlap.',
        'Fast to implement discount ladder v1; migrate when stacking rules multiply.',
        'Fine for 100–400 orders per month before governance complexity grows.',
        'Operational note for discount strategy: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
        'Omnisend implementation for discount strategy should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on discount strategy flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[4]}
      rank={5}
      paragraphs={[
        'Privy starts discount strategy at capture — popup offer must match welcome email one exactly. Strategy fails at front door if popup promises 20% and welcome sends 10%.',
        'Pass redemption intent tag to lifecycle platform at opt-in — coupon popup subscribers enter sensitive path; content subscribers enter full-price path.',
        'Privy not lifecycle executor — discount governance completes in Sequenzy or Klaviyo downstream.',
        'Optimize Privy offer depth first if acquisition trains wrong discount expectations.',
        'Operational note for discount strategy: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
        'Privy implementation for discount strategy should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on discount strategy flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Flow-by-flow rules</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Where discounts belong</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Welcome: only coupon-source subscribers in email one; others email three max. Cart: email two or three, value-capped. Browse: email three only for cold segment. Winback: email three for sensitive only; VIP never. Replenishment: full-price default. Launch: no stacking with other flows for 14 days. Newsletter: alternating proof-only issues for loyalists.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Finance alignment</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Margin floor documentation</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Every discount depth needs finance-approved margin floor by product category — boards, beans, bundles. Platform logic caps codes automatically; marketers cannot override per send without approval. Artisan coffee wholesale-thin margins die quickly from unchecked 20% automation codes.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Transactional stays clean</h2>
      <p>
        Order and shipping emails never carry promotional codes — protects transactional reputation and avoids training buyers to open shipping updates for coupons. Lifecycle and newsletter carry governed offers; transactional carries certainty.
      </p>
      <p>
        Audit every automation quarterly for silent default discounts — browse email three added 10% off during template copy-paste, winback inherited cart code, welcome email two accidentally inherited popup field. Spreadsheet of active codes by flow prevents finance surprises. Vinyl labels running limited pressings especially cannot afford unintended sitewide-code leakage into replenishment reminders.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Offer calendar</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Sync marketing and automation discounts</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Monthly offer calendar shared between email, paid social, and onsite — one owner approves depth. When public sale runs, lifecycle automations respect global suppression flag. Artisan coffee roasters running holiday gift bundle should not simultaneously fire cart 15% from pre-holiday test still live in Klaviyo. Name flows with date suffix when testing discounts so stale tests are obvious in audit. Finance sign-off on maximum code depth by category before Q4 — climbing gear margin cannot absorb accidental 30% automation leak.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Code naming</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Readable Shopify discount codes</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        CART10-VIP versus WELCOME15-CART stacks support confusion — prefix codes by flow and segment. Finance reconciliation uses code prefix in monthly report. Auto-expire codes 72 hours after flow send where possible; evergreen cart codes become sitewide expectation. Vinyl labels running collector full-price segments should use distinct code namespace VIP- never shared with public sale.
      </p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v2 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Why discount strategy fails on generic defaults</h2>
      <p>Shopify merchants treat discount strategy as template toggle — enable flow, set 10% off, move on. That works until margin reports show use incentives without training every shopper to wait recovering revenue while destroying full-price repeat rate. Trigger discipline matters: Segment by discount sensitivity, order history, and engagement. Timing discipline matters: Full-price first for engaged segments; graduated discounts for cold segments; never stack with active promos. Without exclusions, flows collide with welcome offers, replenishment reminders, and VIP early access — training subscribers to wait for stacked discounts.</p>
      <p><strong>Scenario A — Workflow test on Shopify.</strong> Sequenzy playbook encoded suppression and value-based rules for use incentives without training every shopper to wait without week-long flow rebuild.</p><p><strong>Scenario B — Scale merchant 900 orders/mo.</strong> Klaviyo predictive segments and holdout testing optimized discount strategy margin after blanket discount path failed.</p><p><strong>Scenario C — Fast-start boutique.</strong> Omnisend prebuilt journey live in days; graduated when default 10% on every automation became recurring ops issue.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Common mistakes</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">discount strategy anti-patterns</h2>
      <ul class="mt-4 space-y-3 text-[17px] leading-8 text-[#4a2d17]"><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Default 10% on every automation</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Stacking popup + cart + winback discounts</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>No full-price segment treatment</li></ul>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Document collision rules in shared wiki: which flow wins when customer qualifies for cart and winback simultaneously. Test quarterly with staff accounts. Measure margin after incentive, not recovery rate alone — high recovery with negative margin is worse than no email.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Channel mix</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Email, SMS, and transactional boundaries</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Email owns narrative and education for use incentives without training every shopper to wait. SMS belongs as branch when mobile intent outperforms — cart recovery within four hours, drop alerts to VIP SMS-opted segments — not parallel blast to entire list. Transactional order and shipping messages stay separate; marketing suppresses when support ticket open or return in progress.</p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v3 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Advanced discount strategy patterns</h2>
      <p>After baseline use incentives without training every shopper to wait flow works, optimize branches: VIP holdouts without discount, engaged-but-lapsed newsletter readers versus cold buyers, subscription-active customers excluded from conflicting offers. A ceramic studio improved discount strategy margin 19% by routing predicted discount-sensitive profiles only to touch three — full-price loyalists stayed on education path.</p>
      <p>Holdout testing quarterly — 5% segment no promotional discount strategy for thirty days — answers incrementality question finance actually asks. Platform attribution overstates when would-have-purchased-anyway buyers dominate converted cohort.</p>
      <p>SMS branch for discount strategy when mobile opt-in strong: email touch one, SMS four hours if unopened for cart-adjacent workflows — never duplicate same offer both channels within two hours without measurement framework.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Cross-links</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Related workflows for discount strategy</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Pair discount strategy with segmentation hygiene and discount strategy guides — flows fail when segments stale and incentives stack. Review <a class="link" href="/use-cases/segmentation">segmentation</a>, <a class="link" href="/use-cases/discount-strategy">discount strategy</a>, and <a class="link" href="/guides/flow-collision-prevention">collision prevention</a> when scaling send volume.</p>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All apps →</a>
      <a class="link" href="/use-cases/segmentation">Segmentation →</a>
      <a class="link" href="/use-cases/black-friday">Black Friday →</a>
    </div>
  </section>

  <!-- TOOLREVIEW_EXPANSION_v3 -->
  <FaqSection faqs={faqs} title="Discount strategy FAQ" />
</BaseLayout>
