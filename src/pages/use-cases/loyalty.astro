---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const uc = useCaseBySlug('loyalty')!;
const path = '/use-cases/loyalty';
const title = pageTitle(site, 'use-cases/loyalty');
const desc = description(site, 'use-cases/loyalty');

const featuredSlugs = ['sequenzy', 'marsello', 'yotpo-email-sms', 'klaviyo', 'omnisend'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);

const comparisonApps = [
  'sequenzy', 'marsello', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip',
  'privy', 'shopify-email', 'sendlane', 'activecampaign',
].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What Shopify email tool works best with loyalty programs?',
    answer: 'Marsello ranks first when loyalty points and tiers are native to Shopify POS and online. Sequenzy wins for loyalty email strategy — enrollment timing, tier celebration, points expiry warnings without duplicating promo sends. Klaviyo integrates Marsello and Yotpo loyalty with dynamic tier content at scale.',
  },
  {
    question: 'When should loyalty enrollment email send?',
    answer: 'After second order for most DTC — first order proves product fit; second proves repeat intent. Artisan coffee and specialty tea may enroll after first subscription order. Never pitch loyalty to one-time discount buyers who have not repurchased.',
  },
  {
    question: 'How do loyalty emails differ from promotional campaigns?',
    answer: 'Loyalty emails announce points earned, tier achieved, expiring points, exclusive redemption — not generic 20% off. Duplicate promo and loyalty same day trains ignoring both. Dynamic content shows personal points balance; promo shows catalog grid.',
  },
  {
    question: 'Should points expiry emails include discounts?',
    answer: 'Remind points value and easy redemption path — not stack new discount on top. "You have 400 points expiring in 30 days — redeem for free shipping or exclusive mug" beats "20% off plus your points" which confuses margin.',
  },
  {
    question: 'How does loyalty sync with VIP email segments?',
    answer: 'Tier status from Marsello or Yotpo feeds Klaviyo or Sequenzy VIP definition — gold tier equals VIP early access. One source of truth; loyalty platform owns points math, email platform owns send logic and collision with winback and launch.',
  },
  {
    question: 'Can loyalty work for outdoor gear seasonal buyers?',
    answer: 'Yes with recency-weighted tiers — summer hiker who buys again in fall maintains tier; 18-month lapse demotes. Seasonal catalogs need tier rules that tolerate off-season silence without punishing loyal customers.',
  },
  {
    question: 'What loyalty email metrics matter?',
    answer: 'Enrollment rate after second order, repeat purchase frequency post-enrollment, points redemption rate, tier progression speed, unsubscribe on loyalty sends versus promo sends. Redemption without repeat purchase growth means rewards lack perceived value.',
  },
  {
    question: 'Should newsletter mention loyalty points every week?',
    answer: 'Footer balance link yes; hero loyalty pitch no — alternate weekly. Editorial newsletter from vinyl label leads with releases; points reminder in account module. Over-mentioning points feels transactional in editorial context.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All use cases</a>
      <p class="catalog-kicker mt-6">Loyalty</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email tools for loyalty campaigns</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Loyalty email converts repeat buyers into habitual customers — points earned, tier achieved, redemption nudges — distinct from promotional blasts and lifecycle education. An outdoor gear shop whose loyalty tier unlocks repair guides and early shell access needs recognition emails, not the same coupon as bargain hunters. The right Shopify email tool syncs tier status, times enrollment after genuine repeat intent, and warns before points expire without duplicating newsletter content.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This playbook ranks email tools for {uc.job}. We evaluated loyalty platform sync, enrollment timing, collision with promo calendar, and tier celebration automation — not points program feature lists alone. Loyalty email should feel like membership communication — points balance, tier progress, exclusive access — distinct from promotional batch sends that happen to mention rewards in the footer.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps">Full tool catalog</a>
        <a class="btn btn-secondary" href="/use-cases/vip-segments">VIP segments</a>
        <a class="btn btn-secondary" href="/use-cases/replenishment">Replenishment</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Top Shopify email tools for loyalty"
      picks={[
        { label: 'Best loyalty native', tool: 'Marsello', reason: 'Points, tiers, and Shopify POS sync with email triggers for enrollment and redemption.' },
        { label: 'Best email strategy', tool: 'Sequenzy', reason: 'Loyalty lifecycle playbooks — enrollment timing, tier celebration, expiry warnings, promo collision rules.' },
        { label: 'Best Yotpo stack', tool: 'Yotpo Email & SMS', reason: 'Loyalty plus reviews in one ecosystem when UGC and points reinforce each other.' },
        { label: 'Best data depth', tool: 'Klaviyo', reason: 'Dynamic tier content, loyalty segment boolean logic, and reporting at scale.' },
        { label: 'Best fast setup', tool: 'Omnisend', reason: 'Basic loyalty announcement templates when program is simple points-per-dollar.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three loyalty email merchant scenarios</h2>
      <p>
        <strong>Scenario A — Outdoor gear retailer, Marsello tiers.</strong> Klaviyo synced tier status — trail tier at 2 orders, summit tier at 5. Tier achievement email immediate with early access link; points expiry 30-day warning without discount stack. Repeat purchase frequency post-enrollment up 23%; loyalty send unsubscribe 0.6% versus 2.1% on generic promo.
      </p>
      <p>
        <strong>Scenario B — Artisan coffee roaster, subscription-heavy loyalty.</strong> Sequenzy loyalty playbook: enroll after second shipment; redemption email highlights exclusive micro-lot access not percentage off. Points earn on subscribe-and-save emphasized in replenishment handoff. Subscription retention up 8 points year-over-year.
      </p>
      <p>
        <strong>Scenario C — Board game publisher, Yotpo loyalty plus reviews.</strong> Points for review submission fed advocate tier — early expansion access. Loyalty email separate from launch blast; collision rule suppressed promo when tier celebration sent same week. Advocate tier drove 34% of expansion launch day-one revenue.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="catalog-kicker">Execution playbook</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Loyalty email operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-[#4a2d17]">
        <div>
          <h3 class="font-black text-[#24170f]">Trigger</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.trigger}</p>
        </div>
        <div>
          <h3 class="font-black text-[#24170f]">Timing</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.timing}</p>
        </div>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Exclusions</h3>
        <ul class="mt-3 space-y-2">
          {uc.exclusions.map((e) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{e}</li>)}
        </ul>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Metrics</h3>
        <ul class="mt-3 space-y-2">
          {uc.metrics.map((m) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{m}</li>)}
        </ul>
      </div>
      <p class="mt-8 text-[17px] leading-8 text-[#4a2d17]">
        Common mistakes: {uc.mistakes.join('; ')}.
      </p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <p class="catalog-kicker">Comparison table</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">10 Shopify email tools for loyalty</h2>
      <table class="mt-8 w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-[#24170f]/15 text-xs font-black uppercase tracking-wider text-[#9a5b16]">
            <th class="py-3 pr-4">App</th>
            <th class="py-3 pr-4">Loyalty fit</th>
            <th class="py-3 pr-4">Pricing</th>
            <th class="py-3 pr-4">Shopify depth</th>
            <th class="py-3 pr-4">Automation</th>
            <th class="py-3">Rating</th>
          </tr>
        </thead>
        <tbody class="text-[#4a2d17]">
          {comparisonApps.map((app, i) => (
            <tr class="border-b border-[#24170f]/8">
              <td class="py-3 pr-4 font-bold text-[#24170f]"><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td>
              <td class="py-3 pr-4">{app.bestFor}</td>
              <td class="py-3 pr-4">{app.pricing}</td>
              <td class="py-3 pr-4">{app.shopifyDepth}</td>
              <td class="py-3 pr-4">{app.automationDepth}</td>
              <td class="py-3">★ {app.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="catalog-kicker">Detailed reviews</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">Five apps for loyalty campaigns</h2>

    <ToolReview
      app={featuredApps[0]}
      rank={1}
      badge="Editor's choice"
      paragraphs={[
        'Sequenzy leads loyalty email strategy because points programs fail on communication, not point math. Teams launch Marsello then send generic promos — members never understand tier benefits. Sequenzy playbooks map enrollment, celebration, expiry, and redemption emails with promo collision suppression.',
        'Agent-first loyalty timing: "enroll second order, celebrate tier immediately, warn 30 days before expiry, never same day as newsletter promo." Syncs with Marsello or Yotpo webhooks for tier triggers.',
        'Pay-per-send economics suit loyalty — member count grows but not every member needs weekly email. Target tier changes and expiry windows.',
        'Not Marsello for points ledger — pair for native Shopify loyalty infrastructure. Points expiry SMS optional for high-value tiers — email-first default respects inbox unless member opted into SMS loyalty alerts explicitly.',
      ,
        'Operational note for loyalty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Sequenzy implementation for loyalty should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on loyalty flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[1]}
      rank={2}
      paragraphs={[
        'Marsello native Shopify loyalty — points on purchase, POS integration for outdoor gear retail, tier rules, referral points. Email triggers from tier change fire to Klaviyo or Sequenzy via integration.',
        'Best when loyalty is formal program with in-store and online earn. Email execution often downstream in Klaviyo — Marsello owns points truth.',
        'Smaller catalog SMBs benefit from unified loyalty plus email in Marsello ecosystem before graduating to split stack.',
        'Evaluate Yotpo loyalty if already on Yotpo reviews — one vendor versus best-of-breed.',
      ,
        'Operational note for loyalty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Marsello implementation for loyalty should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on loyalty flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[2]}
      rank={3}
      paragraphs={[
        'Yotpo loyalty plus reviews plus email — points for review submission closes advocate loop for pottery and board games. Tier email templates in Yotpo acceptable for SMB.',
        'Dynamic loyalty content in email when paired with Klaviyo for complex segmentation beyond Yotpo defaults.',
        'Strong when UGC and loyalty reinforce — reviewers become tier climbers.',
        'Lifecycle collision rules still need Sequenzy or Klaviyo for launch and winback suppression.',
      ,
        'Operational note for loyalty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Yotpo Email Sms implementation for loyalty should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on loyalty flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[3]}
      rank={4}
      paragraphs={[
        'Klaviyo dynamic blocks show points balance and tier name from Marsello or Yotpo sync — one newsletter template, personalized loyalty module.',
        'Segment boolean: tier equals gold AND points expiring in 30 days — precise expiry campaign without blasting entire program.',
        'Reporting ties loyalty email to repeat purchase cohorts — prove enrollment email incrementality.',
        'Requires clean integration maintenance when loyalty rules change seasonally.',
      ,
        'Operational note for loyalty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Klaviyo implementation for loyalty should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on loyalty flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[4]}
      rank={5}
      paragraphs={[
        'Omnisend basic loyalty announcement templates — tier achieved, points earned — sufficient for simple points-per-dollar without tiers.',
        'Limited dynamic balance sync versus Klaviyo. Fine for first loyalty year.',
        'Graduate when tier logic, expiry, and POS sync complexity grows.',
        'Fast MVP loyalty communication while Marsello or Yotpo program builds.',
      ,
        'Operational note for loyalty: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Omnisend implementation for loyalty should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on loyalty flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Enrollment gate</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Second order, not first popup</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Loyalty pitch on first purchase distracts from post-purchase education and inflates program with one-time discount hunters. Enroll after second order or first subscription renewal — signals repeat intent. Vinyl collectors and climbing gear buyers join when they self-identify as repeat customers, not coupon chasers.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Replenishment handoff</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Points on habit purchases</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Replenishment reminder for artisan coffee can highlight double points on reorder — loyalty value without new discount. Specialty tea subscription earn rate in replenishment email three. Handoff requires replenishment flow to read loyalty status from Marsello sync.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Loyalty is not VIP — but overlaps</h2>
      <p>
        VIP segment is behavioral RFM; loyalty tier is program enrollment. Customer can be VIP without loyalty enroll and vice versa. Email collision rules: tier celebration suppresses generic promo; VIP early access suppresses public launch email. Document priority in <a class="link" href="/use-cases/vip-segments">VIP guide</a>.
      </p>
      <p>
        Referral points emails belong in loyalty lane, not newsletter footer every week. Outdoor gear shops with seasonal points multipliers — double points on off-season purchase — need calendar documentation so November promo team does not stack conflicting multiplier messaging. Marsello webhook to Klaviyo or Sequenzy should fire tier change within minutes, not nightly batch, or celebration email misses emotional peak.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Wholesale exclusion</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">B2B accounts off consumer loyalty</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Specialty tea corporate gifting and pottery wholesale accounts should never enter consumer points program — margin structure differs. Tag B2B in Shopify; exclude from loyalty enrollment and replenishment. Consumer loyalty email to wholesale buyer confuses pricing tiers and creates support debt. Points expiry emails need timezone-aware send — global artisan coffee subscribers expiring points at UTC midnight annoys US West Coast members.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Tier downgrade</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Communicate demotion gracefully</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Lapsed loyalty tier after 12 months inactivity needs email explaining how to regain — not silent point balance change. Outdoor gear seasonal buyers appreciate honest "we paused your summit tier until next purchase" versus mysterious missing perks. Downgrade email is retention opportunity when paired with single relevant product recommendation, not coupon panic.
      </p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v2 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Why loyalty campaigns fails on generic defaults</h2>
      <p>Shopify merchants treat loyalty campaigns as template toggle — enable flow, set 10% off, move on. That works until margin reports show convert repeat buyers into habitual customers recovering revenue while destroying full-price repeat rate. Trigger discipline matters: Points earned, tier achieved, or milestone order count. Timing discipline matters: Welcome to loyalty on 2nd order; tier celebration immediate; expiring points at 30 days before. Without exclusions, flows collide with welcome offers, replenishment reminders, and VIP early access — training subscribers to wait for stacked discounts.</p>
      <p><strong>Scenario A — Workflow test on Shopify.</strong> Sequenzy playbook encoded suppression and value-based rules for convert repeat buyers into habitual customers without week-long flow rebuild.</p><p><strong>Scenario B — Scale merchant 900 orders/mo.</strong> Klaviyo predictive segments and holdout testing optimized loyalty campaigns margin after blanket discount path failed.</p><p><strong>Scenario C — Fast-start boutique.</strong> Omnisend prebuilt journey live in days; graduated when loyalty pitch to one-time discount buyers became recurring ops issue.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Common mistakes</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">loyalty campaigns anti-patterns</h2>
      <ul class="mt-4 space-y-3 text-[17px] leading-8 text-[#4a2d17]"><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Loyalty pitch to one-time discount buyers</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Points expiring without warning</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Loyalty emails duplicating promotional sends</li></ul>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Document collision rules in shared wiki: which flow wins when customer qualifies for cart and winback simultaneously. Test quarterly with staff accounts. Measure margin after incentive, not recovery rate alone — high recovery with negative margin is worse than no email.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Channel mix</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Email, SMS, and transactional boundaries</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Email owns narrative and education for convert repeat buyers into habitual customers. SMS belongs as branch when mobile intent outperforms — cart recovery within four hours, drop alerts to VIP SMS-opted segments — not parallel blast to entire list. Transactional order and shipping messages stay separate; marketing suppresses when support ticket open or return in progress.</p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v3 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Advanced loyalty campaigns patterns</h2>
      <p>After baseline convert repeat buyers into habitual customers flow works, optimize branches: VIP holdouts without discount, engaged-but-lapsed newsletter readers versus cold buyers, subscription-active customers excluded from conflicting offers. A mechanical keyboard atelier improved loyalty campaigns margin 19% by routing predicted discount-sensitive profiles only to touch three — full-price loyalists stayed on education path.</p>
      <p>Holdout testing quarterly — 5% segment no promotional loyalty campaigns for thirty days — answers incrementality question finance actually asks. Platform attribution overstates when would-have-purchased-anyway buyers dominate converted cohort.</p>
      <p>SMS branch for loyalty campaigns when mobile opt-in strong: email touch one, SMS four hours if unopened for cart-adjacent workflows — never duplicate same offer both channels within two hours without measurement framework.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Cross-links</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Related workflows for loyalty campaigns</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Pair loyalty campaigns with segmentation hygiene and discount strategy guides — flows fail when segments stale and incentives stack. Review <a class="link" href="/use-cases/segmentation">segmentation</a>, <a class="link" href="/use-cases/discount-strategy">discount strategy</a>, and <a class="link" href="/guides/flow-collision-prevention">collision prevention</a> when scaling send volume.</p>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All apps →</a>
      <a class="link" href="/use-cases/vip-segments">VIP segments →</a>
      <a class="link" href="/use-cases/replenishment">Replenishment →</a>
    </div>
  </section>

  <!-- TOOLREVIEW_EXPANSION_v3 -->
  <FaqSection faqs={faqs} title="Loyalty FAQ" />
</BaseLayout>
