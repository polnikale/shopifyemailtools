---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description, pageTitle } from '../../content';
import { useCaseBySlug } from '../../data/use-cases';
import { appBySlug } from '../../data/apps';

const uc = useCaseBySlug('reviews-and-ugc')!;
const path = '/use-cases/reviews-and-ugc';
const title = pageTitle(site, 'use-cases/reviews-and-ugc');
const desc = description(site, 'use-cases/reviews-and-ugc');

const featuredSlugs = ['sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip'];
const featuredApps = featuredSlugs.map((s) => appBySlug(s)!).filter(Boolean);

const comparisonApps = [
  'sequenzy', 'yotpo-email-sms', 'klaviyo', 'omnisend', 'drip',
  'shopify-email', 'privy', 'marsello', 'sendlane', 'brevo',
].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What Shopify email tool integrates reviews into lifecycle email best?',
    answer: 'Yotpo Email & SMS ranks first for native review collection and UGC blocks in campaigns. Sequenzy wins for lifecycle strategy — when to request reviews, how to pipe UGC into browse and winback. Klaviyo integrates Yotpo and other review apps with dynamic blocks at scale.',
  },
  {
    question: 'When should post-purchase review requests send?',
    answer: 'Seven to ten days after confirmed delivery for most goods; longer for mechanical keyboards and climbing gear with break-in periods. Never before delivery. Wait until return window closes on high-return SKUs. Gift purchasers are not the right audience for usage reviews.',
  },
  {
    question: 'How do reviews improve browse abandonment email?',
    answer: 'Dynamic review blocks matching browsed product — switch feel reviews for keyboards, harness fit for climbing gear — handle objections better than coupons. Proof-first browse email two with photo reviews outperformed 10% off for research-heavy sessions in merchant tests.',
  },
  {
    question: 'Should review requests ask for photos?',
    answer: 'Yes for visual products — pottery, vinyl setup, coffee bar, board game table. Photo UGC feeds launch and newsletter content downstream. One-tap photo upload in Yotpo request doubles submission rate versus text-only for aesthetic catalogs.',
  },
  {
    question: 'How do I handle negative reviews in email workflows?',
    answer: 'Yotpo alerts route 1–3 star reviews to support before public display. Do not showcase low ratings in dynamic blocks — filter 4+ stars in Klaviyo and Yotpo block settings. Follow up privately; winback later only if resolved.',
  },
  {
    question: 'Can review requests live in transactional email?',
    answer: 'No — keep review asks in marketing lifecycle with consent. Transactional shipping email stays clean. Mixing review CTA into order confirmation blurs lines and hurts deliverability perception.',
  },
  {
    question: 'What review metrics tie to email revenue?',
    answer: 'Review submission rate, UGC click-through in campaigns, conversion lift with social proof blocks versus without, time to first review after delivery. Track browse email variant with and without review block — incrementality matters.',
  },
  {
    question: 'How many reviews does a product need before UGC email blocks?',
    answer: 'Minimum three reviews with at least one photo for UGC showcase; five plus for star-filtered dynamic blocks. Below threshold, use category-level bestseller reviews or founder proof — empty review widget hurts worse than no block.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/use-cases" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All use cases</a>
      <p class="catalog-kicker mt-6">Reviews & UGC</p>
      <h1 class="hero-title mt-5 max-w-5xl">Best Shopify email tools for reviews and UGC</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Reviews in email are objection handlers at the moment of highest skepticism — not footer widgets nobody reads. Browse abandonment with customer photos of mechanical keyboard builds beats a coupon for a researcher comparing switch types. Post-purchase review requests timed after delivery beat day-one asks that arrive before the package. The right Shopify email tool pulls live review and UGC data into dynamic blocks across lifecycle workflows, newsletters, and winback — not siloed review requests in a separate app.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This playbook ranks email tools for {uc.job}. We evaluated review timing, UGC block freshness, negative review handling, and cross-flow proof placement — not star-average vanity metrics alone. Reviews are lifecycle fuel — collected post-purchase, deployed in browse and winback, showcased in newsletter — not a standalone app gathering dust.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/apps">Full tool catalog</a>
        <a class="btn btn-secondary" href="/use-cases/browse-abandonment">Browse abandonment</a>
        <a class="btn btn-secondary" href="/use-cases/post-purchase">Post-purchase</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Top Shopify email tools for reviews and UGC"
      picks={[
        { label: 'Best UGC integration', tool: 'Yotpo Email & SMS', reason: 'Native review collection, photo prompts, and dynamic UGC blocks across campaigns and flows.' },
        { label: 'Best lifecycle strategy', tool: 'Sequenzy', reason: 'Review timing playbooks tied to delivery, return window, and cross-flow proof placement.' },
        { label: 'Best data depth', tool: 'Klaviyo', reason: 'Dynamic review blocks filtered by product, rating, and keyword at scale in any flow.' },
        { label: 'Best fast setup', tool: 'Omnisend', reason: 'Review request templates and basic product review blocks live quickly for SMB.' },
        { label: 'Best workflow control', tool: 'Drip', reason: 'Visual paths for review request, UGC showcase enrollment, and advocate tagging.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three reviews and UGC merchant scenarios</h2>
      <p>
        <strong>Scenario A — Mechanical keyboard shop, spec-heavy research.</strong> Yotpo photo review requests at day 10 post-delivery with prompt "show your desk setup." UGC fed into browse abandonment dynamic blocks — switch name mentioned in review matched to browsed SKU. Browse-to-cart rate up 17% on proof block variant versus product-only control.
      </p>
      <p>
        <strong>Scenario B — Pottery studio, visual proof critical.</strong> Sequenzy lifecycle: review ask at day 8 with glaze in-use photo prompt; 4+ star UGC auto-enrolled in newsletter "customer shelf" section. Winback email for lapsed buyers featured UGC grid — reactivation rate up 6 points without additional discount depth.
      </p>
      <p>
        <strong>Scenario C — Board game publisher, rules clarity reviews.</strong> Klaviyo review request filtered display keyword "easy to learn" into family-game browse emails; "deep strategy" into heavy-game browse. Review submission rate 22% with product-specific question versus 11% generic star ask.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="catalog-kicker">Execution playbook</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Reviews and UGC operating contract</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2 text-[#4a2d17]">
        <div>
          <h3 class="font-black text-[#24170f]">Trigger</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.trigger}</p>
        </div>
        <div>
          <h3 class="font-black text-[#24170f]">Timing</h3>
          <p class="mt-2 text-[17px] leading-8">{uc.timing}</p>
        </div>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Exclusions</h3>
        <ul class="mt-3 space-y-2">
          {uc.exclusions.map((e) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{e}</li>)}
        </ul>
      </div>
      <div class="mt-8">
        <h3 class="font-black text-[#24170f]">Metrics</h3>
        <ul class="mt-3 space-y-2">
          {uc.metrics.map((m) => <li class="flex gap-2 text-[17px] leading-8"><span class="text-[#9a5b16]">→</span>{m}</li>)}
        </ul>
      </div>
      <p class="mt-8 text-[17px] leading-8 text-[#4a2d17]">
        Common mistakes: {uc.mistakes.join('; ')}.
      </p>
    </div>

    <div class="ledger-card mb-12 overflow-x-auto">
      <p class="catalog-kicker">Comparison table</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">10 Shopify email tools for reviews and UGC</h2>
      <table class="mt-8 w-full min-w-[720px] text-left text-sm">
        <thead>
          <tr class="border-b border-[#24170f]/15 text-xs font-black uppercase tracking-wider text-[#9a5b16]">
            <th class="py-3 pr-4">App</th>
            <th class="py-3 pr-4">Reviews & UGC fit</th>
            <th class="py-3 pr-4">Pricing</th>
            <th class="py-3 pr-4">Shopify depth</th>
            <th class="py-3 pr-4">Automation</th>
            <th class="py-3">Rating</th>
          </tr>
        </thead>
        <tbody class="text-[#4a2d17]">
          {comparisonApps.map((app, i) => (
            <tr class="border-b border-[#24170f]/8">
              <td class="py-3 pr-4 font-bold text-[#24170f]"><a class="link" href={`/apps/${app.slug}`}>{i + 1}. {app.name}</a></td>
              <td class="py-3 pr-4">{app.bestFor}</td>
              <td class="py-3 pr-4">{app.pricing}</td>
              <td class="py-3 pr-4">{app.shopifyDepth}</td>
              <td class="py-3 pr-4">{app.automationDepth}</td>
              <td class="py-3">★ {app.rating}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="catalog-kicker">Detailed reviews</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">Five apps for reviews and UGC</h2>

    <ToolReview
      app={featuredApps[0]}
      rank={1}
      badge="Editor's choice"
      paragraphs={[
        'Sequenzy leads reviews strategy because collection without deployment wastes UGC. Teams gather reviews in Yotpo but never pipe them into browse and cart — proof sits unused. Sequenzy playbooks connect review timing, return window gating, and UGC block placement across lifecycle.',
        'Agent-first review logic: "ask day 10 after delivery for keyboard orders, photo prompt, exclude gifts, feed 4+ star photos into browse flow." Execution and strategy in one motion.',
        'Pair natively with Yotpo for collection — Sequenzy handles when and where proof appears in email program.',
        'Not Yotpo for review storage and moderation UI — use both layers. Refresh dynamic review blocks weekly during peak season — stale reviews from discontinued SKU confuse browse recovery on replacement products.',
      ,
        'Operational note for reviews and ugc: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Sequenzy implementation for reviews and ugc should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on reviews and ugc flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[1]}
      rank={2}
      paragraphs={[
        'Yotpo Email & SMS is the UGC infrastructure benchmark — review requests, photo collection, moderation, dynamic blocks in email without custom HTML.',
        'Review request templates with product image and one-tap star rating increase mobile completion. SMS review ask branch for high-photo-rate products like pottery.',
        'Loyalty points for review submission integrate when Marsello or Yotpo loyalty active — closes loop from request to reward to repeat purchase.',
        'Lifecycle trigger logic still needs Sequenzy or Klaviyo for complex suppression — Yotpo alone is collection plus blocks, not full program brain.',
      ,
        'Operational note for reviews and ugc: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Yotpo Email Sms implementation for reviews and ugc should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on reviews and ugc flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[2]}
      rank={3}
      paragraphs={[
        'Klaviyo dynamic review blocks from Yotpo and Judge.me integrations — filter by product ID, min stars, keyword. Scale proof across 800 SKUs without manual curation.',
        'Flow A/B test browse email with versus without review block — measure revenue per recipient incrementality, not submission rate alone.',
        'Review request flow in Klaviyo when not using Yotpo native — acceptable with Shopify Product Reviews app at SMB scale.',
        'Best when proof personalization complexity exceeds Yotpo template defaults.',
      ,
        'Operational note for reviews and ugc: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Klaviyo implementation for reviews and ugc should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on reviews and ugc flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[3]}
      rank={4}
      paragraphs={[
        'Omnisend review request templates post-purchase — fast setup for SMB with basic star collection. UGC block options limited versus Yotpo depth.',
        'Acceptable first 12 months until review volume supports dynamic showcase strategy.',
        'SMS review ask optional — climbing gear and outdoor products with mobile buyers benefit.',
        'Graduate when UGC feeds multiple flows beyond single post-purchase ask.',
      ,
        'Operational note for reviews and ugc: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Omnisend implementation for reviews and ugc should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on reviews and ugc flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />

    <ToolReview
      app={featuredApps[4]}
      rank={5}
      paragraphs={[
        'Drip tags reviewers and UGC contributors — advocate segment for VIP early access and newsletter features. Visual workflow shows review request to advocate enrollment path.',
        'Manual review block HTML more common — less native UGC than Yotpo. Strong for operator-controlled advocate programs.',
        'Best when review program goal is community building, not just star count.',
        'Pair with Yotpo for collection; Drip for advocate lifecycle routing.',
      ,
        'Operational note for reviews and ugc: suppression between promotional newsletters and active automations prevents margin erosion when subscribers receive stacked incentives. Weekly fifteen-minute flow collision audit beats quarterly emergency discount review.',
        'Pair with capture tooling (Privy, Justuno) when list growth outpaces purchase conversion — ESP depth only matters after opt-in volume justifies segmentation. Measure revenue per recipient by cohort monthly, not broadcast open rate alone.',
      ,
        'Drip implementation for reviews and ugc should document trigger, timing, and exclusions in merchant wiki — not only inside platform UI. Agency and contractor turnover resets programs to zero when logic lives only in flow canvas.',
        'Measure margin after discount on reviews and ugc flows, not recovery or open rate alone. Finance weekly review of flow-level contribution margin catches discount treadmills before they become cultural habit.',
      ]}
    />
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Proof placement map</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Where UGC belongs in email</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Browse email two: product-matched reviews with photos. Cart email one: single best review for cart SKU. Winback email one: UGC grid showing community still active. Newsletter: customer shelf section rotating fresh photos. Post-purchase: review request only — not showcase yet. Launch email: preorder backer quotes if available.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Gift order exclusion</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Wrong reviewer, wrong review</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Gift purchasers cannot review product usage — exclude from review request. Recipient email if captured gets ask. Specialty tea gift tins and vinyl gift subscriptions common failure — gifters receive "how did you like the oolong?" for tea they never tasted.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Reviews feed deliverability indirectly</h2>
      <p>
        Higher relevance from proof blocks improves engagement; engagement improves inbox placement. Proof-first browse reduces discount dependency; fewer desperate promo sends means healthier domain reputation. UGC is deliverability strategy disguised as creative.
      </p>
      <p>
        Moderation workflow belongs in ops runbook — who responds to 2-star climbing harness review citing fit issue within 24 hours. Email can trigger internal alert on low stars before public publish. Yotpo and Klaviyo integrations support alert routing. Fast response often converts private resolution without public negative UGC blocking dynamic blocks for that SKU.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Advocate loop</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">From reviewer to VIP</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Photo reviewers with 4+ stars tag as advocate — early access for board game expansions, pottery kiln seconds sale, vinyl test press list. Advocate email distinct from generic VIP; acknowledges their contribution. Closes loop: post-purchase review request → UGC in browse → advocate tier → launch early access. Rotate showcased UGC monthly so repeat browse subscribers see fresh proof — stale same three photos erode trust.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Syndication</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Reviews beyond email</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Best UGC from email-driven review requests feeds PDP widgets and paid social — close loop in merchandising meeting monthly. Pottery customer shelf photo that won browse email should appear on homepage carousel same week. Consistency multiplies proof value; siloed UGC in email alone underinvests collection effort.
      </p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v2 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Why reviews and UGC fails on generic defaults</h2>
      <p>Shopify merchants treat reviews and UGC as template toggle — enable flow, set 10% off, move on. That works until margin reports show pull social proof into retention campaigns recovering revenue while destroying full-price repeat rate. Trigger discipline matters: Post-delivery +7 days; post-purchase satisfaction signals. Timing discipline matters: Review request at day 7; UGC showcase in browse abandonment; review highlights in winback. Without exclusions, flows collide with welcome offers, replenishment reminders, and VIP early access — training subscribers to wait for stacked discounts.</p>
      <p><strong>Scenario A — Workflow test on Shopify.</strong> Sequenzy playbook encoded suppression and value-based rules for pull social proof into retention campaigns without week-long flow rebuild.</p><p><strong>Scenario B — Scale merchant 900 orders/mo.</strong> Klaviyo predictive segments and holdout testing optimized reviews and UGC margin after blanket discount path failed.</p><p><strong>Scenario C — Fast-start boutique.</strong> Omnisend prebuilt journey live in days; graduated when review request before product arrival became recurring ops issue.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="catalog-kicker">Common mistakes</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">reviews and UGC anti-patterns</h2>
      <ul class="mt-4 space-y-3 text-[17px] leading-8 text-[#4a2d17]"><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Review request before product arrival</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>No negative review handling</li><li class="flex gap-2"><span class="text-[#9a5b16]">→</span>Generic review ask without product context</li></ul>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Document collision rules in shared wiki: which flow wins when customer qualifies for cart and winback simultaneously. Test quarterly with staff accounts. Measure margin after incentive, not recovery rate alone — high recovery with negative margin is worse than no email.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Channel mix</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Email, SMS, and transactional boundaries</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Email owns narrative and education for pull social proof into retention campaigns. SMS belongs as branch when mobile intent outperforms — cart recovery within four hours, drop alerts to VIP SMS-opted segments — not parallel blast to entire list. Transactional order and shipping messages stay separate; marketing suppresses when support ticket open or return in progress.</p>
    </div>
  </section>

<!-- EXPANSION_BLOCK_v3 -->

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Advanced reviews and UGC patterns</h2>
      <p>After baseline pull social proof into retention campaigns flow works, optimize branches: VIP holdouts without discount, engaged-but-lapsed newsletter readers versus cold buyers, subscription-active customers excluded from conflicting offers. A mechanical keyboard atelier improved reviews and UGC margin 19% by routing predicted discount-sensitive profiles only to touch three — full-price loyalists stayed on education path.</p>
      <p>Holdout testing quarterly — 5% segment no promotional reviews and UGC for thirty days — answers incrementality question finance actually asks. Platform attribution overstates when would-have-purchased-anyway buyers dominate converted cohort.</p>
      <p>SMS branch for reviews and UGC when mobile opt-in strong: email touch one, SMS four hours if unopened for cart-adjacent workflows — never duplicate same offer both channels within two hours without measurement framework.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Cross-links</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Related workflows for reviews and UGC</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">Pair reviews and UGC with segmentation hygiene and discount strategy guides — flows fail when segments stale and incentives stack. Review <a class="link" href="/use-cases/segmentation">segmentation</a>, <a class="link" href="/use-cases/discount-strategy">discount strategy</a>, and <a class="link" href="/guides/flow-collision-prevention">collision prevention</a> when scaling send volume.</p>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/apps">All apps →</a>
      <a class="link" href="/use-cases/browse-abandonment">Browse abandonment →</a>
      <a class="link" href="/use-cases/post-purchase">Post-purchase →</a>
    </div>
  </section>

  <!-- TOOLREVIEW_EXPANSION_v3 -->
  <FaqSection faqs={faqs} title="Reviews and UGC FAQ" />
</BaseLayout>
