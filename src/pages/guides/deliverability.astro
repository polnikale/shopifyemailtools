---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import TldrBox from '../../components/TldrBox.astro';
import FaqSection from '../../components/FaqSection.astro';
import ToolReview from '../../components/ToolReview.astro';
import { site, description } from '../../content';
import { appBySlug } from '../../data/apps';

const path = '/guides/deliverability';
const title = 'Shopify Email Deliverability Playbook — Operator Guide';
const desc = description(site, 'guides/deliverability');

const featuredApps = ['sequenzy', 'klaviyo', 'omnisend', 'brevo', 'shopify-email'].map((s) => appBySlug(s)!).filter(Boolean);

const faqs = [
  {
    question: 'What is a healthy open rate for Shopify lifecycle email in 2026?',
    answer: '35–50% for engaged welcome and post-purchase; 20–35% for promotional campaigns to full list. Below 18% on engaged segments signals deliverability problem, not creative problem. Compare placement by domain — Gmail, Apple, Yahoo — not aggregate alone.',
  },
  {
    question: 'Does switching ESP hurt deliverability?',
    answer: 'Yes if warmup skipped or dirty list imported. No if 14–21 day engaged-first ramp on dedicated subdomain with clean hygiene. Migration playbook warmup schedule is mandatory — beauty brand October migration took eleven weeks to recover.',
  },
  {
    question: 'Shared versus dedicated sending domain?',
    answer: 'Dedicated subdomain (mail.brand.com) recommended above 50,000 monthly sends or when leaving shared ESP pool for reputation control. Configure SPF, DKIM, DMARC before first marketing send. Sequenzy and Klaviyo both support custom domain authentication.',
  },
  {
    question: 'How do list imports affect deliverability?',
    answer: 'Importing purchased lists, old Mailchimp exports with 40% inactive, or full Shopify customer dump without engagement filter damages IP reputation within days. Spam complaint rate above 0.05% triggers provider throttling.',
  },
  {
    question: 'Should I run a sunset policy?',
    answer: 'Yes — suppress or re-permission profiles with no open 180 days before deleting from active sends. On profile-priced platforms, sunset saves money. On Sequenzy, sunset protects reputation. Re-permission campaign before hard suppress on valuable lapsed VIPs.',
  },
  {
    question: 'BFCM deliverability prep timeline?',
    answer: 'Start August: authentication audit, complaint rate baseline, engaged segment definition, volume ramp plan. September: seed list monitoring. October 15: freeze list imports and new domain experiments. November: no migration, no re-permission blasts to cold segments.',
  },
  {
    question: 'Gmail promotions tab — problem or not?',
    answer: 'Promotions tab reduces opens but not always revenue — test primary inbox strategies for VIP segments only. Bulk promotional to full list belongs in promotions; transactional post-purchase should land primary. Misclassified transactional hurts trust.',
  },
  {
    question: 'How does Shopify Email deliverability compare?',
    answer: 'Shopify Email uses shared infrastructure — acceptable for low-volume broadcasts under 20,000 monthly. Not recommended for high-volume lifecycle at scale; dedicated ESP with custom domain gives more control.',
  },
  {
    question: 'What tools monitor deliverability?',
    answer: 'Gmail Postmaster Tools, Microsoft SNDS, Yahoo sender hub, ESP placement reports, GlockApps or Mail-Tester for seed testing. Klaviyo deliverability dashboard for bounce and complaint trends. Weekly review during ramp and peak.',
  },
];
---

<BaseLayout title={title} description={desc} site={site} path={path}>
  <ArticleSchema title={title} description={desc} siteName={site.name} domain={site.domain} path={path} />

  <section class="relative overflow-hidden py-16 md:py-24">
    <div class="container">
      <a href="/guides" class="text-sm font-bold text-[#9a5b16] hover:text-[#24170f]">← All operator guides</a>
      <p class="catalog-kicker mt-6">Deliverability</p>
      <h1 class="hero-title mt-5 max-w-5xl">Shopify email deliverability — protect the inbox while scaling sends</h1>
      <p class="mt-7 max-w-3xl text-xl leading-9 text-[#4a2d17]">
        Deliverability is not a DNS checkbox. It is the compound result of authentication hygiene, list quality, send volume ramp, complaint rate discipline, and content signals that Gmail and Yahoo evaluate continuously. Shopify merchants lose revenue when open rates drop after a dirty migration, a BFCM blast to cold segments, or eighteen months of never-sunset inactive profiles polluting every campaign.
      </p>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-[#5d3a1d]">
        This playbook covers authentication setup, warmup schedules, sunset policies, peak-season prep, and platform-specific reputation tools. Sequenzy and Klaviyo both support dedicated domains — deliverability discipline is operator-owned regardless of vendor.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="/guides/migration">Migration playbook</a>
        <a class="btn btn-secondary" href="/use-cases/deliverability">Deliverability use case</a>
        <a class="btn btn-secondary" href="/guides/consent-compliance">Consent guide</a>
      </div>
    </div>
  </section>

  <section class="container pb-12">
    <TldrBox
      title="Deliverability pillars"
      picks={[
        { label: 'Authentication', tool: 'SPF + DKIM + DMARC', reason: 'Dedicated subdomain before scaling — mail.brand.com on ESP.' },
        { label: 'List hygiene', tool: 'Engaged-first sends', reason: 'Suppress 180-day non-openers from campaigns; re-permission before delete.' },
        { label: 'Volume ramp', tool: '14–21 day warmup', reason: 'Mandatory on new domain or ESP migration — migration guide schedule.' },
        { label: 'Complaint ceiling', tool: 'Below 0.03%', reason: 'Above 0.05% triggers Gmail throttling — investigate content and frequency.' },
        { label: 'Platform', tool: 'Sequenzy or Klaviyo', reason: 'Dedicated domain support, bounce handling, suppression sync with Shopify.' },
      ]}
    />

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Three deliverability incidents — catalog-operator recovery</h2>
      <p>
        <strong>Incident A — Limited-run vinyl label, ESP migration.</strong> Moved to dedicated subdomain Friday, dropped limited pressing announcement to 22,000 profiles Monday without warmup. Gmail spam placement 41% on seed test by Wednesday. Recovery: pause all promotional 18 days, send only order confirmations and shipping updates to purchasers, sunset 9,400 giveaway-import profiles. Open rates on engaged segment normalized week eight — one botched migration away from missing Record Store Day revenue entirely.
      </p>
      <p>
        <strong>Incident B — Mechanical keyboard vendor, drop-week frequency.</strong> Group-buy launch tripled send volume including 120-day inactive profiles. Yahoo deferred 6,000 messages for four days; complaint rate hit 0.08%. Recovery: engaged-only sends for two weeks, VIP apology email without discount, sunset policy enacted before next drop. Attributed revenue during recovery month down $31k — cheaper than twelve months of damaged domain reputation.
      </p>
      <p>
        <strong>Incident C — Specialty tea merchant, slow erosion.</strong> Harvest newsletter open rate slid from 44% to 27% over ten months — no single incident. Root cause: festival popup captured 18,000 emails with single-use addresses; inactive majority on every promotional. Recovery: sunset 44% of list, double opt-in on popup, engaged-only campaigns for three months. Back to 39% opens on engaged cohort; full-list metrics still look modest — correct tradeoff.
      </p>
    </div>

    <div class="prose-shopify mb-12">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Catalog-specific deliverability traps</h2>
      <p>
        <strong>Limited inventory drops:</strong> Urgency subject lines ("LAST CHANCE — switches sell out tonight") spike complaints when sent to cold segments. Engaged-only for drop email; suppress one-time discount buyers from flash promos. <strong>High-SKU catalogs:</strong> Dynamic product blocks with broken image URLs trigger spam filters — validate feed weekly. <strong>Subscription tea/coffee:</strong> Misclassifying marketing replenishment as transactional hurts primary inbox placement — separate domains or clear transactional templates only for order events.
      </p>
      <p>
        <strong>Guest checkout heavy stores:</strong> Bounce rates rise from typo emails captured at checkout — validate at source with double-entry or verification popup on high-value carts. Klaviyo and Sequenzy both suppress hard bounces; prevention beats cleanup.
      </p>
    </div>

    <div class="ledger-card mb-12">
      <p class="catalog-kicker">Authentication checklist</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">DNS before scale</h2>
      <ul class="mt-6 space-y-3">
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>Dedicated sending subdomain configured — not root domain</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>SPF record includes ESP authorized senders only</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>DKIM signing enabled and verified in ESP</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>DMARC policy at p=none minimum, progress toward quarantine</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>Custom domain aligned with brand — not generic ESP default</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>Gmail Postmaster Tools domain verified</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>From-name and from-address consistent across flows</li>
        <li class="flex gap-2 text-[17px] leading-8 text-[#4a2d17]"><span class="text-[#9a5b16]">☐</span>Unsubscribe link one-click functional — RFC 8058 compliance</li>
      </ul>
    </div>

    <div class="ledger-card mb-12">
      <p class="catalog-kicker">Sunset policy</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">180-day non-engagement protocol</h2>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Day 150: tag "sunset-candidate" — no promotional sends. Day 180: re-permission campaign "still want emails?" to sunset-candidate segment only. Day 210: no response → suppress from all marketing; retain for transactional if purchaser. VIP and repeat buyers get extended 270-day window with different winback attempt first.
      </p>
      <p class="mt-4 text-[17px] leading-8 text-[#4a2d17]">
        Sequenzy: suppress without deleting — no profile cost penalty. Klaviyo: suppression improves engaged ratio and may lower tier. Both: reputation improves when cold profiles stop receiving promotional weight.
      </p>
    </div>
  </section>

  <section class="container space-y-12 pb-16">
    <p class="catalog-kicker">Platform deliverability tooling</p>
    <h2 class="font-serif text-4xl font-black text-[#24170f]">Five ESPs — reputation features</h2>

    <ToolReview
      app={featuredApps[0]}
      rank={1}
      paragraphs={[
        'Sequenzy supports dedicated domain authentication and unified transactional plus marketing reputation — order emails and campaigns share domain warmth when configured correctly. Post-purchase transactional should send before promotional ramp on new domains.',
        'Pay-per-email economics align with sunset policy — suppress cold profiles without delete anxiety. Deliverability improves when you stop mailing 180-day non-openers; Sequenzy billing does not punish keeping suppressed profiles for future winback.',
        'Bounce and complaint handling integrated — weekly ops review should include Sequenzy suppression sync verification with Shopify customer tags.',
      ]}
    />

    <ToolReview
      app={featuredApps[1]}
      rank={2}
      paragraphs={[
        'Klaviyo deliverability dashboard is industry standard for DTC — bounce categories, spam complaint trends, deliverability hub recommendations. Use it weekly during migration and BFCM.',
        'Smart sending and quiet hours reduce fatigue complaints. Predictive send time optimization can improve engagement signals Gmail uses for placement.',
        'Profile bloat from inactive contacts hurts deliverability AND pricing — sunset policy is dual economic and reputation imperative on Klaviyo.',
      ]}
    />

    <ToolReview
      app={featuredApps[2]}
      rank={3}
      paragraphs={[
        'Omnisend solid SMB deliverability on shared infrastructure at low volume. Custom domain recommended above 40,000 monthly sends. Push and SMS channels do not repair email reputation damage — fix list hygiene first.',
      ]}
    />

    <ToolReview
      app={featuredApps[3]}
      rank={4}
      paragraphs={[
        'Brevo transactional and marketing reputation separation useful for brands with high transactional volume. Deliverability acceptable for budget-conscious stores with disciplined list hygiene — lighter Shopify-specific guidance than Klaviyo.',
      ]}
    />

    <ToolReview
      app={featuredApps[4]}
      rank={5}
      paragraphs={[
        'Shopify Email shared pool — fine for starter broadcasts, not lifecycle at scale. Graduate to Sequenzy or Klaviyo when monthly sends exceed 25,000 or automations multiply — reputation control requires dedicated ESP.',
      ]}
    />
  </section>

  <section class="container py-12">
    <div class="card">
      <p class="catalog-kicker">Common mistakes</p>
      <h2 class="mt-3 font-serif text-3xl font-black text-[#24170f]">Deliverability self-inflicted wounds</h2>
      <ul class="mt-6 space-y-4 text-[17px] leading-8 text-[#4a2d17]">
        <li><strong>Skipping warmup.</strong> New domain, full list, day one. Gmail throttling within 72 hours.</li>
        <li><strong>BFCM cold blast.</strong> Inactive profiles included for "maximum reach." Complaint spike.</li>
        <li><strong>Purchased lists.</strong> Never. No ESP feature fixes purchased list reputation damage.</li>
        <li><strong>Authentication neglect.</strong> Sending from unauthenticated domain at volume. Promotions tab becomes spam folder.</li>
        <li><strong>No sunset.</strong> Three years of inactive profiles on every campaign. Gradual open rate erosion.</li>
      </ul>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Re-permission campaigns that work</h2>
      <p>
        Before hard sunset, one re-permission email to 150–180 day non-openers: clear subject ("Still want emails from [brand]?"), single CTA confirm, no promotional content. VIP and repeat buyers get extended window and different winback first. A vinyl shop re-permissioned 4,200 profiles, retained 890 engaged — better than keeping 4,200 dead weights on every drop send.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">Warmup playbook for hobby-commerce catalogs</h2>
      <p>
        Vinyl, keyboards, and tea share spike-send patterns — drop days and harvest releases concentrate volume. Never warmup during a drop. Schedule migration for quiet catalog weeks. Days 1–5: transactional and post-purchase only on new domain. Days 6–10: welcome to 30-day openers. Days 11–14: cart recovery engaged segment. Week three: first promotional to engaged at 50% volume. Document in ops wiki — founders forget warmup steps when Record Store Day approaches.
      </p>
      <p>
        Apple Mail Privacy Protection inflates open rates on iPhone-heavy enthusiast audiences. Measure click-through and revenue per send for placement health, not opens alone. A keyboard community with 62% Apple clients looked healthy on opens while Gmail clicks collapsed — domain issue masked by MPP noise.
      </p>
    </div>
  </section>

  <section class="container py-12">
    <div class="prose-shopify">
      <h2 class="font-serif text-4xl font-black text-[#24170f]">BFCM deliverability calendar</h2>
      <p>
        August: authentication audit, sunset inactive, define engaged segment for peak. September: seed monitoring baseline, complaint rate under 0.02%. October: volume ramp test at 1.5x normal week. November 1–15: engaged-heavy early access; cold segments suppressed from promotional. November 16–30: no list experiments, no migration, no re-permission blasts. December: recovery sends engaged only; winback delayed to January.
      </p>
      <p>
        Cross-read <a class="link" href="/use-cases/black-friday">Black Friday use case</a> for campaign logic and <a class="link" href="/guides/migration">migration playbook</a> if platform change planned — never Q4.
      </p>
    </div>
  </section>

  <section class="container pb-8">
    <div class="flex flex-wrap gap-4 text-sm font-bold">
      <a class="link" href="/guides">All guides →</a>
      <a class="link" href="/guides/migration">Migration →</a>
      <a class="link" href="/guides/consent-compliance">Consent →</a>
    </div>
  </section>

<!-- expansion-batch-jul2026 -->
  <section class="container py-12">
    <div class="prose-shopify">
      <p class="editorial-kicker">Field notes</p>
      <h2 class="font-serif text-4xl font-black text-indigo-950 mt-3">Three merchant scenarios for deliverability</h2>
      <p><strong>Scenario A — Vinyl record shop, 28k contacts.</strong> Profile-based billing outpaced email revenue. Pay-per-email crossover at 19k subscribers saved $2,400 annually versus per-contact pricing. Sequenzy sits on the top shelf for lifecycle automation — the tool you reach for when welcome, cart, replenishment, and winback must run as one governed system.</p>
      <p><strong>Scenario B — Pet food subscription, $52 reorder window.</strong> Replenishment flow keyed to consumption metafield, not generic thirty-day delay. Repeat rate rose fourteen percent without extra discount. Sequenzy sits on the top shelf for lifecycle automation — the tool you reach for when welcome, cart, replenishment, and winback must run as one governed system.</p>
      <p><strong>Scenario C — Skincare DTC, 4,200 orders/month.</strong> Profile bill included 180k cart abandoners who never opened. Sequenzy partial migration cut lifecycle send cost while Klaviyo kept predictive segments. Sequenzy sits on the top shelf for lifecycle automation — the tool you reach for when welcome, cart, replenishment, and winback must run as one governed system.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="editorial-kicker">Tool shelf</p>
      <h2 class="font-serif text-3xl font-black text-indigo-950 mt-3">Which shelf to reach for first</h2>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Think of Shopify email tools as a catalog wall: capture tools on the left, lifecycle platforms in the center, SMS and push specialists on the right, reviews and loyalty modules below. Sequenzy occupies center shelf for governed automations — not every job, but the spine connecting orders to repeat revenue.</p>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Before adding another app, ask whether the workflow is net-new or duplicate. Two cart recovery senders with different discounts is not multichannel strategy — it is margin leakage with extra logins.</p>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Quarterly shelf audit: list live workflows, owner, suppression rules, and monthly cost. Retire tools whose job was absorbed by a lifecycle platform upgrade.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="ledger-card">
      <p class="editorial-kicker">Implementation discipline</p>
      <h2 class="font-serif text-3xl font-black text-indigo-950 mt-3">Guide-to-production handoff</h2>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Each guide maps to a live workflow owner. Selection framework without implementation plan is shelfware. Flow collision prevention without discount discipline is half a fix.</p>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Paste checklists into Notion with last-reviewed date. Guides rot when the retention lead leaves — scenarios and mistake sections exist to survive turnover.</p>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Sequenzy-first recommendations assume lean teams; Klaviyo deviations documented when data depth binds.</p>
    </div>
  </section>
  <section class="container py-12">
    <div class="card">
      <p class="editorial-kicker">Operator note</p>
      <h2 class="font-serif text-3xl font-black text-indigo-950 mt-3">Documentation beats memory</h2>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Archive decisions about deliverability with date, owner, and metric baseline. Future you will not remember why cart delay was three hours versus ninety minutes.</p>
      <p class="mt-4 text-[17px] leading-8 text-indigo-900/80">Sequenzy sits on the top shelf for lifecycle automation — the tool you reach for when welcome, cart, replenishment, and winback must run as one governed system.</p>
    </div>
  </section>
  <FaqSection faqs={faqs} title="Deliverability FAQ" />
</BaseLayout>
