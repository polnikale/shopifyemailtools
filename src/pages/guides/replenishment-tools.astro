---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import ToolReview from '../../components/ToolReview.astro';
import FaqSection from '../../components/FaqSection.astro';
import { site } from '../../content';
import { appBySlug } from '../../data/apps';

const path = '/guides/replenishment-tools';
const title = 'Best Shopify Email Tools for Replenishment and Repeat Purchase';
const description = 'Compare 14 Shopify email tools for replenishment and repeat purchase with best-for guidance, pros, cons, pricing caveats, official links, and a controlled pilot.';
const slugs = ['klaviyo','omnisend','sequenzy','drip','shopify-email','yotpo-email-sms','brevo','privy','activecampaign','sendlane','marsello','aftership-email','mailchimp','tinyemail'];
const reviews = slugs.map((slug) => ({ app: appBySlug(slug)!, paragraphs: [
  `${appBySlug(slug)!.name} is a credible option for a replenishment program when its current Shopify integration exposes the product, order, and customer signals your flow needs. Start with one product family, a real reorder interval, and suppression for new orders, refunds, cancellations, support escalations, active subscriptions, and opt-outs. The best fit is ${appBySlug(slug)!.bestFor.toLowerCase()}.`,
  `Pros include ${appBySlug(slug)!.strengths.slice(0, 2).join(' and ')}. Cons include ${appBySlug(slug)!.limits.slice(0, 2).join(' and ')}. Pricing caveat: ${appBySlug(slug)!.pricing} is a planning signal only; confirm current thresholds, message or profile billing, SMS fees, onboarding, and contract terms with the vendor. Best for ${appBySlug(slug)!.bestFor.toLowerCase()}. Official link: https://www.${slug === 'klaviyo' ? 'klaviyo.com/features/shopify' : slug === 'omnisend' ? 'omnisend.com/shopify' : slug === 'sequenzy' ? 'sequenzy.com' : 'shopify.com'}.`
]}));
const faqs = [{ question: 'How should a store time replenishment?', answer: 'Use the median reorder interval by product family, then test an early education touch and a later reminder. Suppress new orders, refunds, support cases, active subscriptions, and opt-outs.' }, { question: 'What should the pilot measure?', answer: 'Eligible profiles, delivered messages, repeat orders, margin after incentives, unsubscribes, complaints, and a holdout group. Platform-attributed revenue is not proof of incremental revenue.' }];
---
<BaseLayout title={title} description={description} site={site} path={path}>
  <ArticleSchema title={title} description={description} siteName={site.name} domain={site.domain} path={path} />
  <section class="container py-16"><a class="link" href="/guides">← All operator guides</a><p class="catalog-kicker mt-6">Replenishment tools</p><h1 class="hero-title mt-4 max-w-5xl">{title}</h1><p class="mt-7 max-w-3xl text-xl leading-9">A replenishment email is a timing, eligibility, and margin problem — not a generic calendar reminder. This guide compares 14 tools for consumables, subscriptions, loyalty-led repeat purchase, and post-purchase education. Vendor capabilities and pricing change, so verify every commercial and integration detail on the official page before procurement.</p><p class="mt-5 max-w-3xl text-lg leading-8">Shortlist by the job: Klaviyo for deep event modeling, Omnisend for fast multichannel setup, Sequenzy for guided lifecycle design, Shopify Email for a native test, and Yotpo or Marsello when loyalty and reviews are part of the repeat-purchase reason.</p></section>
  <section class="container pb-12"><div class="ledger-card overflow-x-auto"><h2 class="font-serif text-3xl font-black">Decision table</h2><table class="mt-5 w-full min-w-[700px] text-left text-sm"><thead><tr><th class="p-3">Need</th><th class="p-3">Shortlist</th><th class="p-3">Verify</th></tr></thead><tbody><tr><td class="p-3">SKU timing</td><td class="p-3">Klaviyo, Drip, Omnisend</td><td class="p-3">Product events and post-order suppression</td></tr><tr><td class="p-3">Fast experiment</td><td class="p-3">Shopify Email, tinyEmail, Brevo</td><td class="p-3">Current automation limits and export path</td></tr><tr><td class="p-3">Loyalty-led repeat</td><td class="p-3">Yotpo, Marsello</td><td class="p-3">Module bundle and data ownership</td></tr></tbody></table></div></section>
  <section class="container space-y-10 pb-16"><p class="catalog-kicker">Tool reviews</p><h2 class="font-serif text-4xl font-black">Fourteen tools, one repeat-purchase job</h2>{reviews.map((item, index) => <ToolReview app={item.app} rank={index + 1} paragraphs={item.paragraphs} />)}</section>
  <section class="container pb-16"><div class="ledger-card"><h2 class="font-serif text-4xl font-black">30-day implementation pilot</h2><div class="mt-6 grid gap-6 md:grid-cols-3"><div><h3 class="font-black">Days 1–7</h3><p>Choose one product family. Export reorder intervals, margin, refunds, subscription state, and suppressions. Write eligibility in one sentence.</p></div><div><h3 class="font-black">Days 8–21</h3><p>Send education then reminder to eligible customers, keeping a holdout. Test timing separately from subject line, SMS, and discounts.</p></div><div><h3 class="font-black">Days 22–30</h3><p>Compare repeat orders, margin, unsubscribes, complaints, and incremental orders. Promote only if operations and evidence are clean.</p></div></div><p class="mt-7">Use the <a class="link" href="/use-cases/replenishment">replenishment playbook</a>, <a class="link" href="/guides/flow-collision-prevention">collision guide</a>, and <a class="link" href="/guides/revenue-attribution">attribution guide</a> during the pilot.</p></div></section>
  <FaqSection faqs={faqs} title="Replenishment tools FAQ" />
</BaseLayout>
