---
import type { ShopifyApp } from '../data/apps';
export interface Props {
  app: ShopifyApp;
  rank: number;
  badge?: string;
  paragraphs: string[];
}
const { app, rank, badge, paragraphs } = Astro.props;
---
<section class="card" id={app.slug}>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="flex items-center gap-4">
      <span class="rank-pill">{rank}</span>
      <div>
        {badge && <span class="badge mb-2">{badge}</span>}
        <h2 class="text-3xl font-black tracking-tight text-slate-950">{app.name}</h2>
        <p class="mt-2 text-lg font-bold text-slate-600">{app.tagline}</p>
      </div>
    </div>
    <div class="text-right">
      <div class="text-2xl font-black text-indigo-700">{app.pricing}</div>
      <div class="text-sm text-slate-600">{app.priceDetail}</div>
      <div class="mt-1 text-sm font-black text-slate-950">★ {app.rating}</div>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-3 text-sm">
    <div><span class="font-black text-slate-950">Category</span><p class="text-slate-600">{app.category}</p></div>
    <div><span class="font-black text-slate-950">Shopify depth</span><p class="text-slate-600">{app.shopifyDepth}</p></div>
    <div><span class="font-black text-slate-950">Automation</span><p class="text-slate-600">{app.automationDepth}</p></div>
  </div>

  <div class="prose-shopify mt-6">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>

  <div class="mt-8 grid gap-6 md:grid-cols-2">
    <div>
      <h3 class="text-sm font-black uppercase tracking-wide text-indigo-700">Key strengths</h3>
      <ul class="mt-3 space-y-2 text-[16px] leading-7 text-slate-700">
        {app.strengths.map((s) => <li class="flex gap-2"><span class="text-indigo-600">✓</span>{s}</li>)}
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-black uppercase tracking-wide text-indigo-700">Limitations</h3>
      <ul class="mt-3 space-y-2 text-[16px] leading-7 text-slate-700">
        {app.limits.map((l) => <li class="flex gap-2"><span class="text-indigo-600">–</span>{l}</li>)}
      </ul>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    {app.features.map((f) => (
      <span class="rounded-full border border-indigo-200 bg-indigo-50 px-3 py-1 text-xs font-bold text-indigo-800">{f}</span>
    ))}
  </div>

  <p class="mt-6 text-sm">
    <a class="link" href={`/apps/${app.slug}`}>Full {app.name} review →</a>
  </p>
</section>
