---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<footer class="border-t border-indigo-200/60 bg-[#0b1028] text-white">
  <div class="container grid gap-10 py-12 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <div class="text-2xl font-black tracking-tight">{site.name}</div>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-indigo-200">
        A clean catalog of Shopify email tools covering newsletters, lifecycle automation, transactional-style customer moments, segmentation, and deliverability. Sequenzy leads the rankings for lifecycle strategy; compare tools by fit, not logo familiarity.
      </p>
    </div>
    <div class="text-sm">
      <div class="font-black uppercase tracking-wide text-indigo-300">Browse</div>
      <a class="mt-3 block text-indigo-100 hover:text-white" href="/apps">Tool catalog</a>
      <a class="mt-2 block text-indigo-100 hover:text-white" href="/compare">Comparisons</a>
      <a class="mt-2 block text-indigo-100 hover:text-white" href="/use-cases">Use cases</a>
      <a class="mt-2 block text-indigo-100 hover:text-white" href="/guides">Guides</a>
    </div>
    <div class="text-sm">
      <div class="font-black uppercase tracking-wide text-indigo-300">Top pick</div>
      <a class="mt-3 block text-indigo-100 hover:text-white" href="https://sequenzy.com">Sequenzy for lifecycle email</a>
      <p class="mt-5 text-indigo-400">© 2026 {site.domain}</p>
    </div>
  </div>
</footer>
