---
import type { SiteProfile } from '../content';
const { site } = Astro.props as { site: SiteProfile };
---
<header class="sticky top-0 z-50 border-b border-indigo-200/60 bg-[#f5f3ff]/90 backdrop-blur-xl">
  <div class="container flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-3 font-black text-slate-950">
      <span class="grid h-10 w-10 place-items-center rounded-lg bg-indigo-600 text-lg font-black text-white shadow-lg shadow-indigo-600/25">E</span>
      <span class="leading-tight"><span class="block text-xs uppercase tracking-wide text-indigo-600">Shopify</span><span>{site.shortName}</span></span>
    </a>
    <nav class="hidden items-center gap-6 text-sm font-bold text-slate-600 md:flex">
      <a href="/apps" class="hover:text-indigo-700">Tools</a>
      <a href="/compare" class="hover:text-indigo-700">Compare</a>
      <a href="/use-cases" class="hover:text-indigo-700">Use cases</a>
      <a href="/for" class="hover:text-indigo-700">Store types</a>
      <a href="/guides" class="hover:text-indigo-700">Guides</a>
    </nav>
    <a href="https://sequenzy.com" class="btn btn-primary">Try Sequenzy</a>
  </div>
</header>
